Import('env')

# gather sources (both .cpp and .cu files)
l_sources = [ 'patches/WavePropagation1d.cpp',
              'patches/WavePropagation2d.cpp',
              'setups/DamBreak1d/DamBreak1d.cpp',
              'setups/RareRare1d/RareRare1d.cpp',
              'setups/ShockShock1d/ShockShock1d.cpp',
              'setups/Subcritical1d/Subcritical1d.cpp',
              'setups/Supercritical1d/Supercritical1d.cpp',
              'setups/TsunamiEvent1d/TsunamiEvent1d.cpp',
              'setups/TsunamiEvent2d/TsunamiEvent2d.cpp',
              'setups/CircularDamBreak2d/CircularDamBreak2d.cpp',
              'setups/Checkpoint/Checkpoint.cpp',
              'io/Csv.cpp',
              'io/NetCdf.cpp',
              'io/Stations.cpp',
              'setups/ArtificialTsunami2d/ArtificialTsunami2d.cpp'
            ]

# gather unit tests
l_tests = [ 'tests.cpp',
            'solvers/Roe.test.cpp',
            'solvers/F_wave.test.cpp',
            'patches/WavePropagation1d.test.cpp',
            'patches/WavePropagation2d.test.cpp',
            'setups/DamBreak1d/DamBreak1d.test.cpp',
            'setups/RareRare1d/RareRare1d.test.cpp',
            'setups/ShockShock1d/ShockShock1d.test.cpp',
            'setups/Subcritical1d/Subcritical1d.test.cpp',
            'setups/Supercritical1d/Supercritical1d.test.cpp',
            'setups/TsunamiEvent1d/TsunamiEvent1d.test.cpp',
            'setups/TsunamiEvent2d/TsunamiEvent2d.test.cpp',
            'setups/CircularDamBreak2d/CircularDamBreak2d.test.cpp',
            'setups/Checkpoint/Checkpoint.test.cpp',
            'io/Stations.test.cpp',
            'io/Csv.test.cpp',
            'io/NetCdf.test.cpp',
            'setups/ArtificialTsunami2d/ArtificialTsunami2d.test.cpp'
          ]

if 'CUDA_ENABLED' in env['CPPDEFINES']:
    l_sources.extend([
              'cuda/WavePropagation2d_cuda.cu',
              'cuda/WavePropagation2d_kernels.cu',
              'cuda/CudaRegressionTest.cu'
            ])

    # The CUDA regression-test orchestration lives in a separate .cpp that only
    # calls host-side wrapper methods (no kernel launches), so it is compiled
    # with g++. It needs an explicit object name because adding it to l_sources
    # would compile it to cuda/CudaRegressionTest.o, colliding with the object
    # produced by CudaRegressionTest.cu, which shares the same base name.
    env.sources.append(
        env.Object( 'cuda/CudaRegressionTest_host', 'cuda/CudaRegressionTest.cpp' )
    )

    # The CUDA regression-test unit tests reference the host-side wrappers above,
    # so they are only built when CUDA is enabled.
    env.tests.append( env.Object( 'cuda/CudaRegressionTest.test.cpp' ) )

    env.benchmark_cuda = env.Object( 'benchmark_cuda.cpp' )

for l_so in l_sources:
    if l_so.endswith('.cu'):
        env.sources.append( env.CUDAObject( l_so ) )
    else:
        env.sources.append( env.Object( l_so ) )

env.standalone      = env.Object( 'main.cpp' )
env.benchmark       = env.Object( 'benchmark.cpp' )
env.benchmark_grace = env.Object( 'benchmark_grace.cpp' )

for l_te in l_tests:
    env.tests.append( env.Object( l_te ) )

Export('env')